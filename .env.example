# Starter page access password.
# With `output: "export"` (static site), this value is inlined into the JS bundle
# at build time — it is NOT secret. It only acts as a lightweight gate to prevent
# casual access. For real security, use server-side auth.
NEXT_PUBLIC_STARTER_PASSWORD=changeme

# OpenAI API key — required for design generation, code generation, and fix generation (pipeline stages 3-4, 9).
OPENAI_API_KEY=

# GitHub personal access token — required for repo creation and code push (pipeline stage 5).
# Needs `repo` scope.
GITHUB_TOKEN=
